# ============================================================================
# Variáveis de ambiente do Site Público Morabilidade
# Copie este arquivo para .env.local (dev) ou cole no painel da Vercel (prod).
# ============================================================================

# ── API ─────────────────────────────────────────────────────────────────────
# DEV
NEXT_PUBLIC_API_URL=http://localhost:8000

# PROD (descomentar e usar na Vercel)
# NEXT_PUBLIC_API_URL=https://api.morabilidade.com.br

# ── WhatsApp ────────────────────────────────────────────────────────────────
# Formato: 55 + DDD + número, sem espaços, traços ou parênteses.
NEXT_PUBLIC_WHATSAPP=5521997729990

# ── URL pública do site ─────────────────────────────────────────────────────
# Usada em sitemap.xml, robots.txt e Open Graph (compartilhamento WhatsApp/Instagram).
NEXT_PUBLIC_SITE_URL=https://morabilidade.com.br

# ── Sentry (monitoramento de erros) — opcional ──────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
