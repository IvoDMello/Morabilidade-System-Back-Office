# ============================================================================
# Variáveis de ambiente do Painel Administrativo Morabilidade
# Copie este arquivo para .env.local (dev) ou cole no painel da Vercel (prod).
# ============================================================================

# ── API ─────────────────────────────────────────────────────────────────────
# DEV
NEXT_PUBLIC_API_URL=http://localhost:8000

# PROD (descomentar e usar na Vercel)
# NEXT_PUBLIC_API_URL=https://api.morabilidade.com.br

# ── Supabase (autenticação no cliente) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<sua-anon-key>
