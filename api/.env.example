# ============================================================================
# Variáveis de ambiente da API Morabilidade
# Copie este arquivo para .env (dev) ou cole os valores no painel do Railway (prod).
# ============================================================================

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_ANON_KEY=<sua-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<sua-service-role-key>
SUPABASE_JWT_SECRET=<seu-jwt-secret>

# ── Firebase Storage (fotos dos imóveis) ────────────────────────────────────
# Em dev: caminho local; em prod (Railway): conteúdo JSON na env FIREBASE_CREDENTIALS_JSON.
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FIREBASE_STORAGE_BUCKET=<seu-projeto>.appspot.com

# ── E-mail (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_<sua-api-key>
EMAIL_FROM=noreply@morabilidade.com.br
EMAIL_CONTATO=contato@morabilidade.com.br

# ── Aplicação ───────────────────────────────────────────────────────────────
# DEV
APP_ENV=development
APP_SECRET_KEY=mude-esta-chave-em-producao
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
SITE_URL=http://localhost:3001

# PROD (descomentar e usar no Railway)
# APP_ENV=production
# APP_SECRET_KEY=<gerar-32-chars-aleatorios>
# CORS_ORIGINS=https://morabilidade.com.br,https://www.morabilidade.com.br,https://painel.morabilidade.com.br
# SITE_URL=https://morabilidade.com.br

# ── Monitoramento (Sentry) ──────────────────────────────────────────────────
# Deixar em branco para desabilitar em dev
SENTRY_DSN=
