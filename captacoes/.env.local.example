# Supabase (projeto Pro compartilhado do Morabilidade)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Usada só no servidor (route handlers / cron). NUNCA expor no cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX
SENTRY_ORG=morabilidade
SENTRY_PROJECT=captacoes
SENTRY_AUTH_TOKEN=

# Ciclo de vida da mídia (dias até arquivar após negativar/positivar)
RETENCAO_MIDIA_DIAS=90

# Protege o endpoint de cron (Vercel Cron envia este header)
CRON_SECRET=
